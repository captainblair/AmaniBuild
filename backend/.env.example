# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,api
DJANGO_SETTINGS_MODULE=config.settings.development

# Database (PostGIS via Docker)
DATABASE_URL=postgis://amanibuild:amanibuild@localhost:5432/amanibuild

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# CORS (Next.js dev server)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Object storage (MinIO — enable when using docker-compose)
USE_S3_STORAGE=False
AWS_ACCESS_KEY_ID=amanibuild
AWS_SECRET_ACCESS_KEY=amanibuildsecret
AWS_STORAGE_BUCKET_NAME=amanibuild
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_REGION_NAME=us-east-1
AWS_S3_USE_SSL=False

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging
LOG_LEVEL=INFO

# Auth (development only — never enable in production)
AMANIBUILD_EXPOSE_OTP=False
AMANIBUILD_EXPOSE_INVITE_TOKEN=False
